# Production .env template. Copy to /opt/trade-engine/app/.env (chmod 600, owned by trader).
# NEVER commit the real file. Generate the password hash with:
#   .venv/bin/python scripts/hash_password.py '<DASHBOARD_PASSWORD>'
# Generate random secrets with:  openssl rand -hex 32

APP_ENV=prod
BASE_URL=https://arsh.thechosenone.in
DB_PATH=/opt/trade-engine/data/trade.db
APP_SECRET=<openssl rand -hex 32>
KILL_TOKEN=<openssl rand -hex 16>
APP_USERNAME=mrahuja
APP_PASSWORD_HASH=<argon2 hash from scripts/hash_password.py>

# Kite credentials — preferred path is to leave these blank and enter them in the
# in-app Settings page (stored encrypted in the DB). Set here only to bootstrap.
KITE_API_KEY=
KITE_API_SECRET=

# Optional alerts (used by later tasks)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
